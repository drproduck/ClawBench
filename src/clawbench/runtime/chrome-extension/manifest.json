{
  "manifest_version": 3,
  "name": "ClawBench",
  "version": "1.0",
  "description": "Anti-bot-detection browser configuration for benchmarking",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["stealth.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
